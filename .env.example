NODE_ENV=Production
# MongoDB connection string
DATABASE_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/yourDatabase?retryWrites=true&w=majority

# JWT Secrets
ACCESS_TOKEN_SECRET=generate_a_random_secret_key
REFRESH_TOKEN_SECRET=generate_a_random_secret_key

# Paystack
PAYSTACK_SECRET_KEY=sk_test_...

# The URL where your frontend is hosted (e.g. https://graintox.netlify.app)
FRONTEND_URL=https://your-frontend.netlify.app

# The URL where this backend is hosted on Render (e.g. https://graintox-be.onrender.com)
# This is used by the cron job to keep the server awake
BACKEND_URL=https://your-backend.onrender.com

RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=notifications@graintox.com

